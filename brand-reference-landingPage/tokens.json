{
  "brand": {
    "name": "Examigo",
    "mascot": "Exa",
    "positioning": "AI companion that examines students from their own materials",
    "tone": [
      "smart",
      "warm",
      "premium",
      "document-first"
    ]
  },
  "fonts": {
    "heading": {
      "family": "Sora",
      "google": "https://fonts.google.com/specimen/Sora",
      "weights": [600, 700, 800],
      "usage": "Hero headings, section titles, numeric emphasis"
    },
    "body": {
      "family": "Manrope",
      "google": "https://fonts.google.com/specimen/Manrope",
      "weights": [400, 600, 700, 800],
      "usage": "Body copy, labels, helper text, fields, tabs"
    }
  },
  "colors": {
    "page": {
      "value": "#F6F1E8",
      "usage": "Main app page background"
    },
    "card": {
      "value": "#FFFDF8",
      "usage": "Primary elevated cards"
    },
    "cardSoft": {
      "value": "#E7F0EA",
      "usage": "Secondary soft surfaces and calm CTA fills"
    },
    "line": {
      "value": "#DDD5C8",
      "usage": "Borders and quiet dividers"
    },
    "primary": {
      "value": "#1F6C68",
      "usage": "Primary brand action color"
    },
    "primaryPressed": {
      "value": "#195854",
      "usage": "Pressed and deeper brand state"
    },
    "accent": {
      "value": "#F0B44C",
      "usage": "Highlight, progress, and premium accent"
    },
    "ink": {
      "value": "#1E2433",
      "usage": "Primary text"
    },
    "inkMuted": {
      "value": "#5D667A",
      "usage": "Body text and helper text"
    },
    "success": {
      "value": "#23916B",
      "usage": "Success and strong extraction states"
    },
    "danger": {
      "value": "#D45D4B",
      "usage": "Destructive and warning actions"
    },
    "depthA": {
      "value": "#0E4C55",
      "usage": "Deep call surface start"
    },
    "depthB": {
      "value": "#17345F",
      "usage": "Deep call surface end"
    }
  },
  "components": {
    "button": {
      "height": 60,
      "radius": 999,
      "fontFamily": "Sora",
      "fontWeight": 800,
      "variants": {
        "primary": {
          "background": "#1F6C68",
          "foreground": "#FFFFFF"
        },
        "secondary": {
          "background": "#E7F0EA",
          "foreground": "#1E2433"
        },
        "ghost": {
          "background": "transparent",
          "foreground": "#1F6C68",
          "border": "1px solid rgba(31,108,104,0.16)"
        }
      }
    },
    "field": {
      "height": 58,
      "radius": 22,
      "background": "#FFFDF8",
      "border": "#DDD5C8",
      "text": "#1E2433",
      "placeholder": "#98A0AD"
    },
    "radioCard": {
      "radius": 22,
      "background": "#FFFDF8",
      "selectedBackground": "#E7F0EA",
      "selectedBorder": "rgba(31,108,104,0.28)"
    },
    "badge": {
      "height": 42,
      "radius": 999,
      "background": "#FFFFFF",
      "activeBackground": "rgba(31,108,104,0.12)",
      "activeText": "#1F6C68"
    }
  }
}
